# DevPanel configuration. Copy to .env and adjust. Nothing here is secret by
# default; the master password for secrets is never stored in any file.
#   cp .env.example .env

# --- api: Hono REST + static web/dist ---
PANEL_PORT=8899
PANEL_BIND=127.0.0.1          # keep loopback-only; expose via Cloudflare Access / SSH tunnel

# SQLite database. Leave unset to use the portable default <repo>/data/panel.db.
# DB_PATH=/absolute/path/to/panel.db

# --- worker: health poller + daily alert cron ---
# ntfy: leave NTFY_TOPIC empty to log alerts to stdout instead of sending.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
# A request slower than this (ms) is recorded 'degraded'; a non-2xx/timeout is 'down'.
HEALTH_SLOW_MS=2000
HEALTH_TIMEOUT_MS=10000
# Cost anomaly: alert when a service's latest month exceeds cost_month budget by this factor.
COST_OVERRUN=1.2

# --- AI (Ollama) — LOCAL ONLY, never expose externally ---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# Auto-analyze every 30 min is toggled at runtime via settings.ai_auto (UI), default off.

# --- email (reminders via nodemailer). Prefer setting the password here over the UI. ---
# Gmail preset: host smtp.gmail.com, port 587, user = your address, pass = an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- remote access (SPEC step 8, optional) ---
# The public hostname you route to the tunnel; used only in cloudflared/config.yml.
# PANEL_HOSTNAME=panel.example.com
